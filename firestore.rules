rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Guest tags — anyone can read (main app displays them),
    // only signed-in admin can write
    match /episodeTags/{doc} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Episode cache — written by the main app (no auth), read by admin
    match /cache/{doc} {
      allow read:  if true;
      allow write: if true;
    }

    // Transcripts — public read (search), auth-only write (admin upload)
    match /transcripts/{doc} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Play stats — incremented by the main app on every play (no auth),
    // read by admin for analytics
    match /playStats/{doc} {
      allow read:  if true;
      allow write: if true;
    }

  }
}
