rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Guest tags — anyone can read (main app displays them),
    // only signed-in admin can write
    match /episodeTags/{doc} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Episode cache — written by the main app (no auth), read by admin
    match /cache/{doc} {
      allow read:  if true;
      allow write: if true;
    }

  }
}
