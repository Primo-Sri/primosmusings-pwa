{
  "hosting": [
    {
      "target": "primosmusings",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".*",
        "github-upload.html",
        "firestore.rules"
      ],
      "headers": [
        {
          "source": "sw.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
