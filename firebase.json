{
  "hosting": [
    {
      "target": "primos-apps",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".*",
        "github-upload.html"
      ],
      "headers": [
        {
          "source": "sw.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        }
      ]
    }
  ]
}
